# Voorbeeld-secrets voor de OTAP docker-compose.
# Kopieer dit bestand naar .env en vul echte waarden in:
#   cp .env.example .env
#
# .env staat in .gitignore en hoort NOOIT in versiebeheer.
# Dit .env.example bevat met opzet GEEN echte wachtwoorden, alleen placeholders.

DEV_DB_ROOT_PASSWORD=change_me
DEV_DB_PASSWORD=change_me

TEST_DB_ROOT_PASSWORD=change_me
TEST_DB_PASSWORD=change_me

PROD_DB_ROOT_PASSWORD=change_me
PROD_DB_PASSWORD=change_me